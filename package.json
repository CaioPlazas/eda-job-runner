{
  "name": "eda-job-runner",
  "displayName": "EDA Job Runner",
  "description": "Tool-agnostic sidebar for running and tracking EDA compile/simulation jobs (Xcelium, Questa, or any custom script) without leaving VS Code.",
  "version": "0.39.0",
  "publisher": "CaioPlazas",
  "license": "GPL-3.0",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CaioPlazas/eda-job-runner.git"
  },
  "bugs": {
    "url": "https://github.com/CaioPlazas/eda-job-runner/issues"
  },
  "homepage": "https://github.com/CaioPlazas/eda-job-runner#readme",
  "galleryBanner": {
    "color": "#0d3b66",
    "theme": "dark"
  },
  "keywords": [
    "eda",
    "verilog",
    "systemverilog",
    "vhdl",
    "rtl",
    "asic",
    "fpga",
    "simulation",
    "uvm",
    "questa",
    "dsim",
    "icarus",
    "verilator",
    "xcelium"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:edaJobRunnerView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eda-job-runner",
          "title": "EDA Jobs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "eda-job-runner": [
        {
          "id": "edaJobRunnerView",
          "name": "Jobs"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "edaJobRunnerView",
        "contents": "No EDA jobs configured yet.\n[Add Job](command:eda-job-runner.addJob)\n\nJobs are stored in `.vscode/eda-jobs.json` and can also be edited by hand.",
        "when": "workspaceFolderCount != 0"
      },
      {
        "view": "edaJobRunnerView",
        "contents": "Open a folder to configure EDA jobs.",
        "when": "workspaceFolderCount == 0"
      }
    ],
    "commands": [
      {
        "command": "eda-job-runner.addJob",
        "title": "EDA: Add Job",
        "icon": "$(add)"
      },
      {
        "command": "eda-job-runner.configureJob",
        "title": "EDA: Configure Job",
        "icon": "$(gear)"
      },
      {
        "command": "eda-job-runner.deleteJob",
        "title": "EDA: Delete Job",
        "icon": "$(trash)"
      },
      {
        "command": "eda-job-runner.duplicateJob",
        "title": "EDA: Duplicate Job",
        "icon": "$(copy)"
      },
      {
        "command": "eda-job-runner.saveJobAsTemplate",
        "title": "EDA: Save Job as Template..."
      },
      {
        "command": "eda-job-runner.refresh",
        "title": "EDA: Refresh Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "eda-job-runner.configureShell",
        "title": "EDA: Configure Shell & Environment",
        "icon": "$(terminal)"
      },
      {
        "command": "eda-job-runner.configureTools",
        "title": "EDA: Configure Tool Setup",
        "icon": "$(tools)"
      },
      {
        "command": "eda-job-runner.configureParams",
        "title": "EDA: Configure Parameters",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "eda-job-runner.openLogViewer",
        "title": "EDA: Log Viewer",
        "icon": "$(checklist)"
      },
      {
        "command": "eda-job-runner.addFolder",
        "title": "EDA: Add Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "eda-job-runner.addJobInFolder",
        "title": "EDA: Add Job in Folder",
        "icon": "$(add)"
      },
      {
        "command": "eda-job-runner.runFolder",
        "title": "EDA: Run Folder (sequentially)",
        "icon": "$(run-all)"
      },
      {
        "command": "eda-job-runner.stopFolder",
        "title": "EDA: Stop Folder",
        "icon": "$(debug-stop)"
      },
      {
        "command": "eda-job-runner.renameFolder",
        "title": "EDA: Rename Folder"
      },
      {
        "command": "eda-job-runner.deleteFolder",
        "title": "EDA: Delete Folder",
        "icon": "$(trash)"
      },
      {
        "command": "eda-job-runner.moveJobToFolder",
        "title": "EDA: Move to Folder...",
        "icon": "$(folder-opened)"
      },
      {
        "command": "eda-job-runner.runJob",
        "title": "EDA: Run Job",
        "icon": "$(play)"
      },
      {
        "command": "eda-job-runner.stopJob",
        "title": "EDA: Stop Job",
        "icon": "$(debug-stop)"
      },
      {
        "command": "eda-job-runner.reRunLast",
        "title": "EDA: Re-run Last (same params/seed)",
        "icon": "$(redo)"
      },
      {
        "command": "eda-job-runner.stopAllRuns",
        "title": "EDA: Stop All Runs",
        "icon": "$(debug-stop)"
      },
      {
        "command": "eda-job-runner.clearRunHistory",
        "title": "EDA: Clear Run History",
        "icon": "$(clear-all)"
      },
      {
        "command": "eda-job-runner.openLog",
        "title": "EDA: Open Latest Log",
        "icon": "$(output)"
      },
      {
        "command": "eda-job-runner.openLogHistory",
        "title": "EDA: Open Log History...",
        "icon": "$(history)"
      },
      {
        "command": "eda-job-runner.followLog",
        "title": "EDA: Follow Running Log",
        "icon": "$(eye)"
      },
      {
        "command": "eda-job-runner.liveLog",
        "title": "EDA: Live Log (tail)",
        "icon": "$(pulse)"
      },
      {
        "command": "eda-job-runner.runDefaultJob",
        "title": "EDA: Run Default Job",
        "icon": "$(play-circle)"
      }
