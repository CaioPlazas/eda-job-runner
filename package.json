{
  "name": "eda-job-runner",
  "displayName": "EDA Job Runner",
  "description": "Tool-agnostic sidebar for running and tracking EDA compile/simulation jobs (Xcelium, Questa, or any custom script) without leaving VS Code.",
  "version": "0.14.0",
  "publisher": "CaioPlazas",
  "license": "GPL-3.0",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CaioPlazas/eda-job-runner.git"
  },
  "bugs": {
    "url": "https://github.com/CaioPlazas/eda-job-runner/issues"
  },
  "homepage": "https://github.com/CaioPlazas/eda-job-runner#readme",
  "galleryBanner": {
    "color": "#0d3b66",
    "theme": "dark"
  },
  "keywords": [
    "eda",
    "verilog",
    "systemverilog",
    "vhdl",
    "rtl",
    "asic",
    "fpga",
    "simulation",
    "uvm",
    "questa",
    "dsim",
    "icarus",
    "verilator",
    "xcelium"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:edaJobRunnerView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eda-job-runner",
          "title": "EDA Jobs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "eda-job-runner": [
        {
          "id": "edaJobRunnerView",
          "name": "Jobs"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "edaJobRunnerView",
        "contents": "No EDA jobs configured yet.\n[Add Job](command:eda-job-runner.addJob)\n\nJobs are stored in `.vscode/eda-jobs.json` and can also be edited by hand.",
        "when": "workspaceFolderCount != 0"
      },
      {
        "view": "edaJobRunnerView",
        "contents": "Open a folder to configure EDA jobs.",
        "when": "workspaceFolderCount == 0"
      }
    ],
    "commands": [
      {
        "command": "eda-job-runner.addJob",
        "title": "EDA: Add Job",
        "icon": "$(add)"
      },
      {
        "command": "eda-job-runner.configureJob",
        "title": "EDA: Configure Job",
        "icon": "$(gear)"
      },
      {
        "command": "eda-job-runner.deleteJob",
        "title": "EDA: Delete Job",
        "icon": "$(trash)"
      },
      {
        "command": "eda-job-runner.duplicateJob",
        "title": "EDA: Duplicate Job",
        "icon": "$(copy)"
      },
      {
        "command": "eda-job-runner.refresh",
        "title": "EDA: Refresh Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "eda-job-runner.configureShell",
        "title": "EDA: Configure Shell & Environment",
        "icon": "$(terminal)"
      },
      {
        "command": "eda-job-runner.configureTools",
        "title": "EDA: Configure Tool Setup",
        "icon": "$(tools)"
      },
      {
        "command": "eda-job-runner.addFolder",
        "title": "EDA: Add Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "eda-job-runner.addJobInFolder",
        "title": "EDA: Add Job in Folder",
        "icon": "$(add)"
      },
      {
        "command": "eda-job-runner.renameFolder",
        "title": "EDA: Rename Folder"
      },
      {
        "command": "eda-job-runner.deleteFolder",
        "title": "EDA: Delete Folder",
        "icon": "$(trash)"
      },
      {
        "command": "eda-job-runner.moveJobToFolder",
        "title": "EDA: Move to Folder...",
        "icon": "$(folder-opened)"
      },
      {
        "command": "eda-job-runner.runJob",
        "title": "EDA: Run Job",
        "icon": "$(play)"
      },
      {
        "command": "eda-job-runner.stopJob",
        "title": "EDA: Stop Job",
        "icon": "$(debug-stop)"
      },
      {
        "command": "eda-job-runner.reRunLast",
        "title": "EDA: Re-run Last (same params/seed)",
        "icon": "$(redo)"
      },
      {
        "command": "eda-job-runner.stopAllRuns",
        "title": "EDA: Stop All Runs",
        "icon": "$(debug-stop)"
      },
      {
        "command": "eda-job-runner.openLog",
        "title": "EDA: Open Latest Log",
        "icon": "$(output)"
      },
      {
        "command": "eda-job-runner.openLogHistory",
        "title": "EDA: Open Log History...",
        "icon": "$(history)"
      },
      {
        "command": "eda-job-runner.followLog",
        "title": "EDA: Follow Running Log",
        "icon": "$(eye)"
      },
      {
        "command": "eda-job-runner.liveLog",
        "title": "EDA: Live Log (tail)",
        "icon": "$(pulse)"
      },
      {
        "command": "eda-job-runner.runDefaultJob",
        "title": "EDA: Run Default Job",
        "icon": "$(play-circle)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "eda-job-runner.addJob",
          "when": "view == edaJobRunnerView",
          "group": "navigation@1"
        },
        {
          "command": "eda-job-runner.addFolder",
          "when": "view == edaJobRunnerView",
          "group": "navigation@2"
        },
        {
          "command": "eda-job-runner.configureShell",
          "when": "view == edaJobRunnerView",
          "group": "navigation@3"
        },
        {
          "command": "eda-job-runner.configureTools",
          "when": "view == edaJobRunnerView",
          "group": "navigation@4"
        },
        {
          "command": "eda-job-runner.refresh",
          "when": "view == edaJobRunnerView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^edaJob-(?!running)/ && !edaJobRunner.anyJobRunning",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-idle && !edaJobRunner.anyJobRunning",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && (viewItem == edaJob-running || viewItem == edaJobGroup-running) && edaJobRunner.multiRunsEnabled",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJob-running",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopAllRuns",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-running",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobRun-running",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.openLog",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobRun-)/",
          "group": "inline@2"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^edaJob-(?!running)/ && !edaJobRunner.anyJobRunning",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-idle && !edaJobRunner.anyJobRunning",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && (viewItem == edaJob-running || viewItem == edaJobGroup-running) && edaJobRunner.multiRunsEnabled",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJob-running",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.stopAllRuns",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-running",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobRun-running",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.openLog",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobRun-)/",
          "group": "1_run@2"
        },
        {
          "command": "eda-job-runner.followLog",
          "when": "view == edaJobRunnerView && viewItem == edaJob-running",
          "group": "1_run@3"
        },
        {
          "command": "eda-job-runner.liveLog",
          "when": "view == edaJobRunnerView && viewItem =~ /^edaJob-/",
          "group": "1_run@4"
        },
        {
          "command": "eda-job-runner.openLogHistory",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "1_run@5"
        },
        {
          "command": "eda-job-runner.reRunLast",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-(?!running)|edaJobRun-(?!running))/",
          "group": "1_run@6"
        },
        {
          "command": "eda-job-runner.configureJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@1"
        },
        {
          "command": "eda-job-runner.duplicateJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@2"
        },
        {
          "command": "eda-job-runner.deleteJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@3"
        },
        {
          "command": "eda-job-runner.moveJobToFolder",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@4"
        },
        {
          "command": "eda-job-runner.addJobInFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.addJobInFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@1"
        },
        {
          "command": "eda-job-runner.renameFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@2"
        },
        {
          "command": "eda-job-runner.deleteFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@3"
        }
      ],
      "commandPalette": [
        {
          "command": "eda-job-runner.configureJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.deleteJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.duplicateJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.reRunLast",
          "when": "false"
        },
        {
          "command": "eda-job-runner.stopAllRuns",
          "when": "false"
        },
        {
          "command": "eda-job-runner.openLog",
          "when": "false"
        },
        {
          "command": "eda-job-runner.openLogHistory",
          "when": "false"
        },
        {
          "command": "eda-job-runner.followLog",
          "when": "false"
        },
        {
          "command": "eda-job-runner.liveLog",
          "when": "false"
        },
        {
          "command": "eda-job-runner.addJobInFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.renameFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.deleteFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.moveJobToFolder",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "eda-job-runner.runDefaultJob",
        "key": "f5",
        "when": "edaJobRunner.hasDefaultJob && !inDebugMode"
      }
    ],
    "configuration": {
      "title": "EDA Job Runner",
      "properties": {
        "eda-job-runner.shellPath": {
          "type": "string",
          "default": "bash",
          "description": "Shell used to run jobs (name on PATH or absolute path). The invocation is chosen per shell family so dotfile/module-based environment setup is available: bash/zsh use a login shell (`-lc`), tcsh/csh use `-c` (which still sources ~/.tcshrc). Override the arguments with `eda-job-runner.shellArgs`. Use the Shell & Environment panel (terminal icon in the EDA Jobs view) to configure this, or to copy your VS Code terminal shell."
        },
        "eda-job-runner.shellArgs": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null,
          "markdownDescription": "Arguments passed to `eda-job-runner.shellPath` to run a job. Leave `null` to auto-select by shell family (bash/zsh → `-lc`, tcsh/csh → `-c`, etc.). When set, put the token `${command}` where the assembled command should be inserted; if no element contains it, the command is appended as the final argument. Example for csh sites: `[\"-c\", \"${command}\"]`."
        },
        "eda-job-runner.env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "markdownDescription": "Extra environment variables merged on top of the inherited environment for every job. Supports `${workspaceFolder}` and `${env:NAME}` substitution. For heavier setup (module loads, sourcing an activation script) prefer the `setup` block in `.vscode/eda-jobs.json`."
        },
        "eda-job-runner.killGracePeriodSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Seconds to wait after sending SIGTERM before escalating to SIGKILL when stopping a job."
        },
        "eda-job-runner.logMaxSizeMB": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "Maximum size (MB) captured per run log. Once exceeded, capture stops (with a marker) but the job keeps running."
        },
        "eda-job-runner.logRetentionCount": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Number of past run logs to keep per job. Older logs are deleted automatically after each new run."
        },
        "eda-job-runner.stripAnsiCodes": {
          "type": "boolean",
          "default": true,
          "description": "Strip ANSI color/cursor escape codes from captured output before writing to the log file, so logs read cleanly as plain text."
        },
        "eda-job-runner.failOnLogErrors": {
          "type": "boolean",
          "default": true,
          "description": "Mark a job as failed when its log contains UVM_ERROR/UVM_FATAL or compile errors, even if the tool process exited 0. EDA simulators do not return a non-zero exit code on a failed UVM test, so exit code alone is not a reliable pass/fail signal."
        },
        "eda-job-runner.postSetupCwd": {
          "type": "string",
          "default": "",
          "markdownDescription": "Directory a job's shell starts in — after its own startup (sourcing `.bashrc`/`.zshrc`/`.cshrc` etc.) — before the workspace setup and the job's command run. A job's own **Working Directory** then resolves relative to this instead of the workspace root. Supports `${workspaceFolder}` and `${env:NAME}`. Leave blank to keep resolving against the workspace root (default). A job can override this individually in its Advanced settings. Configure from the Shell & Environment panel."
        },
        "eda-job-runner.experimentalMultipleRuns": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Experimental.** Allow more than one job — or more than one instance of the *same* job — to run at the same time, instead of the default one-job-at-a-time restriction. A job's own **Repeat count** (Advanced settings) runs sequentially regardless of this setting; this only affects overlapping *separate* Run clicks."
        }
      }
    }
  },
  "scripts": {
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node16",
    "compile": "npm run esbuild-base -- --sourcemap",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
