        {
          "command": "eda-job-runner.duplicateJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.saveJobAsTemplate",
          "when": "false"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "false"
        },
        {
          "command": "eda-job-runner.reRunLast",
          "when": "false"
        },
        {
          "command": "eda-job-runner.stopAllRuns",
          "when": "false"
        },
        {
          "command": "eda-job-runner.clearRunHistory",
          "when": "false"
        },
        {
          "command": "eda-job-runner.openLog",
          "when": "false"
        },
        {
          "command": "eda-job-runner.openLogHistory",
          "when": "false"
        },
        {
          "command": "eda-job-runner.followLog",
          "when": "false"
        },
        {
          "command": "eda-job-runner.liveLog",
          "when": "false"
        },
        {
          "command": "eda-job-runner.addJobInFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.runFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.stopFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.renameFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.deleteFolder",
          "when": "false"
        },
        {
          "command": "eda-job-runner.moveJobToFolder",
          "when": "false"
