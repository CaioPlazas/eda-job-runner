    "menus": {
      "view/title": [
        {
          "command": "eda-job-runner.addJob",
          "when": "view == edaJobRunnerView",
          "group": "navigation@1"
        },
        {
          "command": "eda-job-runner.addFolder",
          "when": "view == edaJobRunnerView",
          "group": "navigation@2"
        },
        {
          "command": "eda-job-runner.configureShell",
          "when": "view == edaJobRunnerView",
          "group": "navigation@3"
        },
        {
          "command": "eda-job-runner.configureTools",
          "when": "view == edaJobRunnerView",
          "group": "navigation@4"
        },
        {
          "command": "eda-job-runner.configureParams",
          "when": "view == edaJobRunnerView",
          "group": "navigation@5"
        },
        {
          "command": "eda-job-runner.openLogViewer",
          "when": "view == edaJobRunnerView",
          "group": "navigation@6"
        },
        {
          "command": "eda-job-runner.refresh",
          "when": "view == edaJobRunnerView",
          "group": "navigation@7"
        }
      ],
      "view/item/context": [
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^edaJob-(?!running)/ && !edaJobRunner.anyJobRunning",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-idle && !edaJobRunner.anyJobRunning",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJob-running",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopAllRuns",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-running",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobRun-running",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.openLog",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobRun-)/",
          "group": "inline@2"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^edaJob-(?!running)/ && !edaJobRunner.anyJobRunning",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.runJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-idle && !edaJobRunner.anyJobRunning",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJob-running",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.stopAllRuns",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-running",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.stopJob",
          "when": "view == edaJobRunnerView && viewItem == edaJobRun-running",
          "group": "1_run@1"
        },
        {
          "command": "eda-job-runner.openLog",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobRun-)/",
          "group": "1_run@2"
        },
        {
          "command": "eda-job-runner.followLog",
          "when": "view == edaJobRunnerView && viewItem == edaJob-running",
          "group": "1_run@3"
        },
        {
          "command": "eda-job-runner.liveLog",
          "when": "view == edaJobRunnerView && viewItem =~ /^edaJob-/",
          "group": "1_run@4"
        },
        {
          "command": "eda-job-runner.openLogHistory",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "1_run@5"
        },
        {
          "command": "eda-job-runner.reRunLast",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-(?!running)|edaJobRun-(?!running))/",
          "group": "1_run@6"
        },
        {
          "command": "eda-job-runner.configureJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@1"
        },
        {
          "command": "eda-job-runner.duplicateJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@2"
        },
        {
          "command": "eda-job-runner.deleteJob",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@3"
        },
        {
          "command": "eda-job-runner.moveJobToFolder",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@4"
        },
        {
          "command": "eda-job-runner.saveJobAsTemplate",
          "when": "view == edaJobRunnerView && viewItem =~ /^(edaJob-|edaJobGroup-)/",
          "group": "2_modification@5"
        },
        {
          "command": "eda-job-runner.clearRunHistory",
          "when": "view == edaJobRunnerView && viewItem == edaJobGroup-idle",
          "group": "2_modification@6"
        },
        {
          "command": "eda-job-runner.runFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "inline@1"
        },
        {
          "command": "eda-job-runner.stopFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "inline@2"
        },
        {
          "command": "eda-job-runner.addJobInFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "inline@3"
        },
        {
          "command": "eda-job-runner.runFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@1"
        },
        {
          "command": "eda-job-runner.stopFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@2"
        },
        {
          "command": "eda-job-runner.addJobInFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@3"
        },
        {
          "command": "eda-job-runner.renameFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@4"
        },
        {
          "command": "eda-job-runner.deleteFolder",
          "when": "view == edaJobRunnerView && viewItem == edaFolder",
          "group": "1_folder@5"
        }
