    "keybindings": [
      {
        "command": "eda-job-runner.runDefaultJob",
        "key": "f5",
        "when": "edaJobRunner.hasDefaultJob && !inDebugMode"
      }
    ],
    "configuration": {
      "title": "EDA Job Runner",
      "properties": {
        "eda-job-runner.shellPath": {
          "type": "string",
          "default": "bash",
          "description": "Shell used to run jobs (name on PATH or absolute path). The invocation is chosen per shell family so dotfile/module-based environment setup is available: bash/zsh use a login shell (`-lc`), tcsh/csh use `-c` (which still sources ~/.tcshrc). Override the arguments with `eda-job-runner.shellArgs`. Use the Shell & Environment panel (terminal icon in the EDA Jobs view) to configure this, or to copy your VS Code terminal shell."
        },
        "eda-job-runner.shellArgs": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null,
          "markdownDescription": "Arguments passed to `eda-job-runner.shellPath` to run a job. Leave `null` to auto-select by shell family (bash/zsh → `-lc`, tcsh/csh → `-c`, etc.). When set, put the token `${command}` where the assembled command should be inserted; if no element contains it, the command is appended as the final argument. Example for csh sites: `[\"-c\", \"${command}\"]`."
        },
        "eda-job-runner.env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "markdownDescription": "Extra environment variables merged on top of the inherited environment for every job. Supports `${workspaceFolder}` and `${env:NAME}` substitution. For heavier setup (module loads, sourcing an activation script) prefer the `setup` block in `.vscode/eda-jobs.json`."
        },
        "eda-job-runner.killSignals": {
          "type": "array",
          "default": [
            { "signal": "SIGINT", "graceSeconds": 5 },
            { "signal": "SIGTERM", "graceSeconds": 5 },
            { "signal": "SIGKILL" }
          ],
          "items": {
            "type": "object",
            "properties": {
              "signal": {
                "type": "string",
                "enum": ["SIGINT", "SIGTERM", "SIGKILL", "SIGHUP", "SIGQUIT", "SIGUSR1", "SIGUSR2", "SIGABRT"]
              },
              "graceSeconds": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": ["signal"]
          },
          "markdownDescription": "Ordered escalation sequence used when stopping a job (signalled against the whole process group, so it reaches the entire `make`/shell/simulator tree). Each stage waits `graceSeconds` (falling back to `killGracePeriodSeconds` when omitted) before moving to the next; a final `SIGKILL` is always appended even if omitted here. Defaults to `SIGINT` first since many EDA tools release their license cleanly on ctrl+c but not on `SIGTERM`."
        },
        "eda-job-runner.killGracePeriodSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Fallback grace period (seconds) for a killSignals stage that doesn't specify its own graceSeconds."
        },
        "eda-job-runner.logMaxSizeMB": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "Maximum amount (MB) of a run's output fed into error/warning parsing and Fail/Pass pattern matching. Once exceeded, parsing stops (with a marker) but the job keeps running and its full output keeps being recorded to the log file regardless -- since v0.30.0 the log file is written directly by the job's own process, so this setting no longer limits the file's own size (use logRetentionCount to bound total disk usage)."
        },
        "eda-job-runner.logRetentionCount": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "description": "Number of past run logs to keep per job. Older logs are deleted automatically after each new run. 0 = unlimited (no count-based limit -- use logRetentionMaxSizeMB instead, or alongside this)."
        },
        "eda-job-runner.logRetentionMaxSizeMB": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Total size (MB), summed across a job's own past run logs, to keep. Once exceeded, the oldest surviving runs are deleted (after logRetentionCount's own cap, if that's also set) until back under this limit. 0 = off (no size-based limit)."
        },
        "eda-job-runner.stripAnsiCodes": {
          "type": "boolean",
          "default": true,
          "description": "No longer has any effect since v0.30.0: the log file is now written directly by the job's own process (needed so capture survives a window reload) and can no longer be selectively stripped before writing. Error/warning parsing always strips ANSI codes internally regardless of this setting. Kept registered for backward compatibility with existing settings.json files."
        },
        "eda-job-runner.failOnLogErrors": {
          "type": "boolean",
          "default": true,
          "description": "Mark a job as failed when its log contains UVM_ERROR/UVM_FATAL or compile errors, even if the tool process exited 0. EDA simulators do not return a non-zero exit code on a failed UVM test, so exit code alone is not a reliable pass/fail signal."
        },
        "eda-job-runner.postSetupCwd": {
          "type": "string",
          "default": "",
          "markdownDescription": "Directory a job's shell starts in — after its own startup (sourcing `.bashrc`/`.zshrc`/`.cshrc` etc.) — before the workspace setup and the job's command run. A job's own **Working Directory** then resolves relative to this instead of the workspace root. Supports `${workspaceFolder}` and `${env:NAME}`. Leave blank to keep resolving against the workspace root (default). A job can override this individually in its Advanced settings. Also the *default* directory Tool Setup scans a tool from — a tool can override that individually too, so the same script registered from two different folders can be scanned independently. Configure from the Shell & Environment panel."
        },
        "eda-job-runner.logsDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Where run logs are stored, instead of the default `.eda-runner/logs` under the workspace root. Absolute, or relative to the workspace root; supports `${workspaceFolder}` and `${env:NAME}`. Leave blank to keep the default. A job can override this individually in its Advanced settings. Configure (with a folder-browse button) from the Shell & Environment panel."
        },
        "eda-job-runner.experimentalMultipleRuns": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Experimental.** Allow more than one *different* job to run at the same time, instead of the default one-job-at-a-time restriction. A single job can never run concurrently with itself either way — its own **Repeat count** (Advanced settings) is the only way to run it again, always sequentially."
        },
        "eda-job-runner.experimentalAutoSaveJobConfig": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Experimental.** Auto-save a job's Configure form as you edit it (on typing/change/blur/Enter, debounced) instead of relying on the Save button — Save still works either way, and the tab never closes on its own."
        }
      }
    }
  },
  "scripts": {
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node16",
    "compile": "npm run esbuild-base -- --sourcemap",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
